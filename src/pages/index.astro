---
import Layout from "../layouts/Layout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import VideoBackground from "../components/ui/VideoBackground.astro";
import { SectionHeader } from "../components/ui/SectionHeader";
import { SkillGrid } from "../components/ui/SkillGrid";
import { Terminal } from "../components/ui/Terminal";
import { ContactForm } from "../components/cta/ContactForm";
import { skillsData } from "../config/skills.config";
import { siteConfig } from "../config/site.config";
---

<Layout>
  <Header />

  <main>
    <!-- ═══════════════════════════════════
         HERO
    ════════════════════════════════════ -->
    <section
      id="hero"
      class="video-section relative min-h-screen flex items-center justify-center pt-16 overflow-hidden"
    >
      <VideoBackground videoName="hero-bg" />

      <!-- Radial glow behind text -->
      <div
        class="absolute inset-0 pointer-events-none"
        style="background: radial-gradient(ellipse 80% 60% at 50% 50%, rgba(99,102,241,0.12) 0%, transparent 70%);"
      >
      </div>

      <div
        class="relative z-10 w-full max-w-7xl mx-auto px-6 lg:px-8 text-center"
      >
        <!-- Availability badge -->
        <div
          class="inline-flex items-center gap-2.5 px-5 py-2 rounded-full mb-10 opacity-0 animate-fade-up"
          style="
            background: rgba(39,200,64,0.08);
            border: 1px solid rgba(39,200,64,0.25);
            backdrop-filter: blur(10px);
            animation-delay: 0s;
          "
        >
          <span class="relative flex h-2 w-2">
            <span
              class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"
            ></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-400"
            ></span>
          </span>
          <span
            class="text-sm font-medium"
            style="color: rgba(134,239,172,0.9);"
          >
            Ouvert aux opportunités
          </span>
        </div>

        <!-- H1 -->
        <h1
          class="text-5xl sm:text-7xl md:text-8xl font-bold mb-8 text-white opacity-0 animate-fade-up"
          style="letter-spacing: -0.05em; line-height: 1.0; animation-delay: 0.1s;"
        >
          Ensemble, construisons<br />
          <span
            style="background: linear-gradient(90deg, #818cf8 0%, #c084fc 50%, #f472b6 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; filter: drop-shadow(0 0 30px rgba(129,140,248,0.4));"
          >
            le futur.
          </span>
        </h1>

        <!-- Sub -->
        <p
          class="text-lg md:text-xl max-w-2xl mx-auto mb-10 opacity-0 animate-fade-up"
          style="color: #94a3b8; line-height: 1.7; animation-delay: 0.2s;"
        >
          L'évolution technologique est constante. Mon objectif est de
          transformer la complexité de l'écosystème IT moderne en solutions
          simples, performantes et évolutives pour accompagner votre croissance.
        </p>

        <!-- À propos (glassmorphism card) -->
        <div
          class="max-w-2xl mx-auto mb-12 p-6 rounded-2xl text-left opacity-0 animate-fade-up"
          style="
            background: rgba(8,14,24,0.5);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(99,102,241,0.15);
            box-shadow: 0 8px 32px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.04);
            animation-delay: 0.3s;
          "
        >
          <p
            class="text-xs font-mono font-semibold uppercase tracking-widest mb-3"
            style="color: #818cf8;"
          >
            // À propos
          </p>
          <p style="color: #94a3b8; line-height: 1.7; font-size: 0.975rem;">
            Passionné par les technologies émergentes et l'architecture système,
            je suis un informaticien généraliste capable d'intervenir sur
            l'ensemble de la chaîne de valeur d'un projet IT — du réseau à l'IA
            en passant par le développement et la cybersécurité.
          </p>
        </div>

        <!-- CTA -->
        <div
          class="flex flex-col sm:flex-row items-center justify-center gap-4 opacity-0 animate-fade-up"
          style="animation-delay: 0.4s;"
        >
          <a href="#dev" class="btn-primary text-base">
            Découvrir mon expertise
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <a
            href={siteConfig.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-7 py-3.5 rounded-xl font-semibold text-base text-white transition-all duration-300"
            style="border: 1px solid rgba(99,102,241,0.25); background: rgba(99,102,241,0.05);"
            onmouseover="this.style.borderColor='rgba(99,102,241,0.5)'; this.style.background='rgba(99,102,241,0.12)'; this.style.boxShadow='0 0 25px rgba(99,102,241,0.2)'"
            onmouseout="this.style.borderColor='rgba(99,102,241,0.25)'; this.style.background='rgba(99,102,241,0.05)'; this.style.boxShadow='none'"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path>
            </svg>
            GitHub
          </a>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div
        class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-0 animate-fade-up"
        style="animation-delay: 0.8s;"
      >
        <span class="text-xs font-mono" style="color: #475569;">scroll</span>
        <div
          class="w-px h-10"
          style="background: linear-gradient(to bottom, rgba(99,102,241,0.7), transparent);"
        >
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════
         DÉVELOPPEMENT
    ════════════════════════════════════ -->
    <section
      id="dev"
      class="relative py-32 section-divider"
      style="background: linear-gradient(to bottom, #020408, #060b14);"
    >
      <!-- Radial ambient -->
      <div
        class="absolute inset-0 pointer-events-none"
        style="background: radial-gradient(ellipse 60% 50% at 20% 50%, rgba(99,102,241,0.06) 0%, transparent 70%);"
      >
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">
        <SectionHeader
          client:visible
          tag="// 01 Développement"
          title="Chaque problème a sa solution."
          description="De l'architecture globale à la ligne de code finale, je conçois des applications robustes. Mon approche pragmatique traduit vos besoins métiers en outils digitaux sur mesure, fiables et maintenables."
        />

        <div class="mb-16">
          <Terminal client:visible />
        </div>

        <SkillGrid client:visible category="dev" />
      </div>
    </section>

    <!-- ═══════════════════════════════════
         RÉSEAU
    ════════════════════════════════════ -->
    <section
      id="network"
      class="video-section relative py-32 min-h-[80vh] flex items-center section-divider overflow-hidden"
    >
      <VideoBackground videoName="network-bg" />

      <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 w-full">
        <SectionHeader
          client:visible
          tag="// 02 Réseau"
          title="Toutes les routes mènent à Rome."
          description="Une infrastructure solide est la colonne vertébrale de toute entreprise. Je déploie, optimise et sécurise vos architectures réseaux pour garantir une connectivité sans faille et une haute disponibilité."
        />
        <SkillGrid client:visible category="network" />
      </div>
    </section>

    <!-- ═══════════════════════════════════
         DATA
    ════════════════════════════════════ -->
    <section
      id="data"
      class="video-section relative py-32 min-h-[80vh] flex items-center section-divider overflow-hidden"
    >
      <VideoBackground videoName="data-bg" />

      <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 w-full">
        <SectionHeader
          client:visible
          tag="// 03 Data"
          title="Anticiper chaque évènement."
          description="La donnée est votre atout le plus précieux. Je vous aide à la collecter, la nettoyer et l'analyser pour en extraire des insights stratégiques concrets, pour des décisions éclairées."
        />
        <SkillGrid client:visible category="data" />
      </div>
    </section>

    <!-- ═══════════════════════════════════
         INTELLIGENCE ARTIFICIELLE
    ════════════════════════════════════ -->
    <section
      id="ai"
      class="video-section relative py-32 min-h-[80vh] flex items-center section-divider overflow-hidden"
    >
      <VideoBackground videoName="ai-bg" />

      <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 w-full">
        <SectionHeader
          client:visible
          tag="// 04 Intelligence Artificielle"
          title="Vos processus en automatique."
          description="L'IA n'est plus le futur, c'est le présent. J'intègre les derniers modèles de machine learning et les LLMs pour automatiser vos tâches, optimiser vos flux de travail et augmenter votre productivité."
        />
        <SkillGrid client:visible category="ai" />
      </div>
    </section>

    <!-- ═══════════════════════════════════
         CYBERSÉCURITÉ
    ════════════════════════════════════ -->
    <section
      id="cyber"
      class="video-section relative py-32 min-h-[80vh] flex items-center section-divider overflow-hidden"
    >
      <VideoBackground videoName="cyber-bg" />

      <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 w-full">
        <SectionHeader
          client:visible
          tag="// 05 Cybersécurité"
          title="Une forteresse impénétrable."
          description="Face aux menaces croissantes, la protection de vos actifs numériques est non négociable. J'applique les meilleures pratiques pour auditer, durcir et défendre vos systèmes contre les vulnérabilités."
        />
        <SkillGrid client:visible category="cyber" />
      </div>
    </section>

    <!-- ═══════════════════════════════════
         CONTACT CTA
    ════════════════════════════════════ -->
    <section
      id="contact"
      class="relative py-32 section-divider overflow-hidden"
      style="background: linear-gradient(to bottom, #060b14, #020408);"
    >
      <!-- Radial orb -->
      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full pointer-events-none"
        style="background: radial-gradient(circle, rgba(99,102,241,0.1) 0%, transparent 70%); filter: blur(20px);"
      >
      </div>

      <div class="relative z-10 max-w-5xl mx-auto px-6 lg:px-8 text-center">
        <p
          class="text-xs font-mono font-semibold uppercase tracking-widest mb-5"
          style="color: #818cf8;"
        >
          // Travaillons ensemble
        </p>
        <h2
          class="text-4xl md:text-6xl font-bold mb-6 text-white"
          style="letter-spacing: -0.04em;"
        >
          Prêt à concrétiser<br />
          <span
            style="background: linear-gradient(90deg,#818cf8,#c084fc,#f472b6); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;"
          >
            votre vision&nbsp;?
          </span>
        </h2>
        <p class="text-xl mb-16 max-w-xl mx-auto" style="color: #94a3b8;">
          Discutons de votre projet ou explorez mes réalisations sur GitHub.
        </p>

        <div class="mb-16">
          <ContactForm client:visible />
        </div>

        <a
          href={siteConfig.githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 px-8 py-4 rounded-xl font-semibold text-white transition-all duration-300"
          style="border: 1px solid rgba(99,102,241,0.25); background: rgba(99,102,241,0.05);"
          onmouseover="this.style.borderColor='rgba(99,102,241,0.5)'; this.style.background='rgba(99,102,241,0.12)'; this.style.boxShadow='0 0 30px rgba(99,102,241,0.2)'"
          onmouseout="this.style.borderColor='rgba(99,102,241,0.25)'; this.style.background='rgba(99,102,241,0.05)'; this.style.boxShadow='none'"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path
              d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
            ></path>
          </svg>
          Explorer mon GitHub
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
