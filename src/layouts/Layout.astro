---
import '../styles/global.css';
import { siteConfig } from '../config/site.config';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = siteConfig.title, 
  description = siteConfig.description 
} = Astro.props;
---

<!doctype html>
<html lang="fr" class="scroll-smooth bg-background text-text-primary">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
  </head>
  <body class="min-h-screen selection:bg-accent/30 selection:text-white">
    <slot />
  </body>
</html>
