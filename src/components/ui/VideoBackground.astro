---
interface Props {
  videoName: string;
}
const { videoName } = Astro.props;
// The videoName is passed WITH extension (e.g. "hero-bg.webm") or without
// We always look for the .webm file in /videos/
const baseName = videoName.replace(/\.(mp4|webm)$/, '');
const webmSrc = `/videos/${baseName}.webm`;
const mp4Src  = `/videos/${baseName}.mp4`;
---

<video
  autoplay
  loop
  muted
  playsinline
  class="absolute inset-0 w-full h-full object-cover -z-20"
  style="opacity: 0.45;"
>
  <source src={webmSrc} type="video/webm" />
  <source src={mp4Src} type="video/mp4" />
</video>

<!-- Layered overlay: top/bottom darkening + subtle horizontal vignette -->
<div class="absolute inset-0 -z-10 pointer-events-none">
  <!-- Vertical gradient: darken top/bottom, less in middle to let video breathe -->
  <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(2,4,8,0.88) 0%, rgba(2,4,8,0.45) 30%, rgba(2,4,8,0.45) 70%, rgba(2,4,8,0.88) 100%);"></div>
  <!-- Horizontal vignette -->
  <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(2,4,8,0.55) 0%, transparent 50%, rgba(2,4,8,0.55) 100%);"></div>
</div>
