---
import '../../styles/global.css';
import { siteConfig } from '../../config/site.config';
import { Github } from 'lucide-react';
---

<header
  id="main-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  style="background: rgba(2,4,8,0.7); backdrop-filter: blur(20px) saturate(180%); border-bottom: 1px solid rgba(99,102,241,0.1);"
>
  <!-- Top accent line -->
  <div class="h-px w-full" style="background: linear-gradient(90deg, transparent, rgba(99,102,241,0.8), rgba(168,85,247,0.8), transparent);"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="#" class="group flex items-center gap-2">
        <span class="text-lg font-heading font-bold tracking-tight text-white group-hover:gradient-text transition-all duration-300"
              style="letter-spacing: -0.03em;">
          Kieran<span style="background: linear-gradient(90deg,#818cf8,#c084fc); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;">Lelong</span>
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-1">
        {[
          { href: '#dev',     label: 'Dev' },
          { href: '#network', label: 'Réseau' },
          { href: '#data',    label: 'Data' },
          { href: '#ai',      label: 'IA' },
          { href: '#cyber',   label: 'Cyber' },
        ].map(({ href, label }) => (
          <a
            href={href}
            class="px-4 py-2 text-sm font-medium rounded-lg transition-all duration-200"
            style="color: rgba(148,163,184,1);"
            onmouseover="this.style.color='white'; this.style.background='rgba(99,102,241,0.1)'"
            onmouseout="this.style.color='rgba(148,163,184,1)'; this.style.background='transparent'"
          >
            {label}
          </a>
        ))}
      </nav>

      <!-- Actions -->
      <div class="flex items-center gap-3">
        <a
          href={siteConfig.githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center w-9 h-9 rounded-lg transition-all duration-200"
          style="border: 1px solid rgba(99,102,241,0.15); color: rgba(148,163,184,1);"
          onmouseover="this.style.borderColor='rgba(99,102,241,0.5)'; this.style.color='white'; this.style.boxShadow='0 0 15px rgba(99,102,241,0.3)'"
          onmouseout="this.style.borderColor='rgba(99,102,241,0.15)'; this.style.color='rgba(148,163,184,1)'; this.style.boxShadow='none'"
          aria-label="GitHub"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>

        <a
          href={siteConfig.linktreeUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center w-9 h-9 rounded-lg transition-all duration-200"
          style="border: 1px solid rgba(99,102,241,0.15); color: rgba(148,163,184,1);"
          onmouseover="this.style.borderColor='rgba(99,102,241,0.5)'; this.style.color='white'; this.style.boxShadow='0 0 15px rgba(99,102,241,0.3)'"
          onmouseout="this.style.borderColor='rgba(99,102,241,0.15)'; this.style.color='rgba(148,163,184,1)'; this.style.boxShadow='none'"
          aria-label="Linktree"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M7.953 15.066c-.08.163-.08.326 0 .489.08.163.24.244.4.244h1.68v5.01c0 1.303 1.076 2.191 2.38 2.191 1.3 0 2.38-.888 2.38-2.191v-5.01h1.68c.16 0 .32-.081.4-.244.08-.163.08-.326 0-.489l-4.06-7.82c-.08-.163-.24-.244-.4-.244-.16 0-.32.081-.4.244l-4.06 7.82zM21.538 9.15l-4.842-4.842c-.187-.187-.44-.293-.707-.293H7.953c-.267 0-.52.106-.707.293L2.404 9.15c-.586.586-.586 1.536 0 2.121l4.842 4.842c.187.187.44.293.707.293h8.036c.267 0 .52-.106.707-.293l4.842-4.842c.586-.586.586-1.535 0-2.121z"/>
          </svg>
        </a>

        <a
          href="#contact"
          class="btn-primary text-sm px-5 py-2.5"
        >
          Solutions
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  // Scroll progress bar
  const header = document.getElementById('main-header');
  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        const scrolled = window.scrollY > 20;
        if (header) {
          if (scrolled) {
            header.style.background = 'rgba(2,4,8,0.92)';
          } else {
            header.style.background = 'rgba(2,4,8,0.7)';
          }
        }
        ticking = false;
      });
      ticking = true;
    }
  });
</script>
